        "view_to_submit_rate"
      ],
      "dimensions": [
        "form_id",
        "form_role",
        "lead_type",
        "residential_complex_id"
      ]
    },
    {
      "id": "source_performance",
      "title": "Источники и размещения",
      "metrics": [
        "valid_submissions",
        "online_submissions",
        "offline_submissions",
        "online_submission_share",
        "offline_submission_share",
        "classification_coverage_rate"
      ],
      "dimensions": [
        "lead_source",
        "placement",
        "form_id",
        "lead_type",
        "residential_complex_id"
      ]
    },
    {
      "id": "content_assist",
      "title": "Справочный контент",
      "metrics": [
        "content_assisted_submissions",
        "content_assisted_share"
      ],
      "dimensions": [
        "placement",
        "form_id",
        "form_role",
